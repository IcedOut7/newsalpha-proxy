# PS3838 (Pinnacle) Credentials
PS3838_USERNAME=your_username
PS3838_PASSWORD=your_password
PS3838_BASE_URL=https://api.ps3838.com

# Kalshi Credentials
KALSHI_KEY_ID=your_key_id
KALSHI_PRIVATE_KEY_PATH=./kalshi_private.pem
KALSHI_BASE_URL=https://api.elections.kalshi.com

# Anthropic API (for News Dashboard)
ANTHROPIC_API_KEY=your_anthropic_key

# Bot Settings
DRY_RUN=true
BANKROLL=1000
MAX_LEG_STAKE=2

# Telegram Notifications
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
